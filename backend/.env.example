# CareerPilot backend environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# These are SERVER-SIDE secrets and must never be exposed to the browser.

# Supabase project URL (same as the frontend one).
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — full access, bypasses Row Level Security. Server only!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key for AI resume analysis / interview prep.
OPENAI_API_KEY=your-openai-api-key

# Port your backend server listens on.
PORT=8080
