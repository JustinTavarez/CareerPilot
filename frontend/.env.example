# CareerPilot frontend environment variables.
# Copy this file to `.env.local` and fill in the values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API).
#
# Only the public anon key belongs here. NEVER put the service_role key or the
# OpenAI API key in the frontend - those are server-side secrets.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
